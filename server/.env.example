# CTA Train Tracker API key
# Register at: https://www.transitchicago.com/developers/traintrackerapiinfo.aspx
CTA_API_KEY=

# Set to "true" to use generated mock data without hitting the CTA API
# Automatically enabled when CTA_API_KEY is not set
MOCK_MODE=false

# Express server port (Vite proxy targets this in development)
PORT=3001

NODE_ENV=development
